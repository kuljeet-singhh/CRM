{
  "installCommand": "npm install --include=dev",
  "rewrites": [
    { "source": "/auth/:path*", "destination": "/api" },
    { "source": "/api/:path*", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/.prisma/**"
    }
  },
  "crons": [
    { "path": "/api/cron/gmail-daily-sync", "schedule": "0 0 * * *" },
    { "path": "/api/cron/outlook-daily-sync", "schedule": "0 0 * * *" },
    { "path": "/api/cron/calendar-daily-sync", "schedule": "0 1 * * *" }
  ]
}
