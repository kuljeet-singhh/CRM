  "functions": { "api/index.ts": { "maxDuration": 60 } },
  "crons": [
    { "path": "/api/cron/sync-worker", "schedule": "* * * * *" },
    { "path": "/api/cron/gmail-watch-renew", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/gmail-daily-sync", "schedule": "0 0 * * *" },
    { "path": "/api/cron/outlook-renew", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/outlook-daily-sync", "schedule": "0 0 * * *" }
  ]
}
